function headlineLengthCnt(){
  document.fonts.ready.then(() => {
    for(let i = 1; i <= 3; i++) {
      
      shrinkr(document.getElementById("f" + i + "_subheadline_txt"));
      shrinkr(document.getElementById("f" + i + "_headline_txt"));
      
      let fontSize = parseInt(variables.legal_size_hex_weight_xy.split('|')[0]);
      const legalElement = document.getElementById('legal_text' + i);
      const height = legalElement.clientHeight;
      let scrollHeight = legalElement.scrollHeight;

      while(scrollHeight > height) {
        fontSize = fontSize - .5;
        // legalElement.style.fontSize = fontSize + 'px';
        TweenMax.set('.legalText', {fontSize});
        scrollHeight = legalElement.scrollHeight;
        if(fontSize == 0) {
          break;
        }
      }
    }
  });


  const hdline = [variables.f1_headline_txt, variables.f2_headline_txt, variables.f3_headline_txt];
  const hdlinElmt = [f1_headline_txt,f2_headline_txt,f3_headline_txt];
  const subhdlinElmt = [f1_subheadline_txt,f2_subheadline_txt,f3_subheadline_txt];

  let count = 0;
  let ind = 0;

  for(let i = 0; i < hdline.length; i++){
    if(hdline[i].length > count ){
      count = hdline[i].length
      ind = i;
    }
  }
 
  // setTimeout(() => {
  //   shrinkr(hdlinElmt[ind]);
  // }, 100);

  setTimeout(() => {

    hdlinElmt.forEach((element, i) => {
      if(element){
        if(Number(subhdlinElmt[i].style.fontSize.split("px")[0]) >= Number(hdlinElmt[i].style.fontSize.split("px")[0])){
          subhdlinElmt[i].style.fontSize = (Number(hdlinElmt[i].style.fontSize.split("px")[0])* 0.68) + "px";
