function setDefaultMetaData(){
  let style = variables.offer_hex_weight_strike_hex_thickness_bullet_hex_size, offer, strike, bullet;
  

  if(style){
     style = style.split("|");
     
     if(style[0]){
       offer = style[0].split(",");
       document.head.appendChild(
        document.createElement("style")
      ).innerHTML = `offer{color:${offer[0]}; font-weight: ${offer[1]}}`;
     }

     if(style[1]){
    
       strike = style[1].split(",");
       document.head.appendChild(
        document.createElement("style")
      ).innerHTML = `
    .strike {
      position: relative;
      display: inline-block;
      color: inherit;
    }
    .strike::after {
      content: "";
      position: absolute;
      top:25%;
      left: 0;
      width: 100%;
      height: ${strike[1]}px;
      background-color: ${strike[0]};
      transform: rotate(5deg); 
        transform-origin: left top;
      pointer-events: none;
    }
      `;
     }
     
     if(style[2]){
      bullet = style[2].split(",");
       document.head.appendChild(
        document.createElement("style")
      ).innerHTML = `li::marker,color{color:${bullet[0]};} li,bullet{ font-size:${bullet[1]}px } `;
     }
     
  }

}

function setMetaData(element, copy, size_hex_weight_xy) {
  var styling = size_hex_weight_xy.split("|")
   if (copy && copy.trim()) {
    let modifiedCopy =
        "<span>" +
        copy.trim().replace(regex, (e) => {
          const saveMatch = e.match(/SAVE(\s?\d+)/);
          if (saveMatch) {
            // Extract the number after SAVE
            const saveNumber = saveMatch[1];
            return `<span class="noWrap">${e.includes("Usa el c├│digo") ? "Usa el c├│digo:<br>" : "Use code:<br>"}SAVE${saveNumber}</span>`;
          }
          return `<span class="noWrap">${e}</span>`;
        }) +
        "</span>";
        modifiedCopy = modifiedCopy.replace(/<sm>/g, "</br><sm>");
        element.innerHTML = modifiedCopy;
  }
  if(styling[0] && styling[0].trim()){
    element.style.setProperty("font-size", styling[0] + 'px')
  }
  if(styling[1] && styling[1].trim()){
    element.style.setProperty("color", styling[1])
  }
  if(styling[2] && styling[2].trim()){
    element.style.setProperty("font-weight", styling[2])
  }
  if(styling[3]){
     setXY(element, styling[3]);
  }
}




function setCta(){
  cta_txt.innerHTML = variables.cta_txt.trim();
  var ctabtn = variables.cta_txt_size_hex_hexHover_weight_xy.split("|")
  if(ctabtn[0] && ctabtn[0].trim()){
    cta_txt.style.setProperty("font-size", ctabtn[0].trim() + "px")
  }
  if(ctabtn[1] && ctabtn[1].trim()){
    cta_txt.style.setProperty("color", ctabtn[1].trim())
  }
  if(ctabtn[3] && ctabtn[3].trim()){
    cta_txt.style.setProperty("font-weight", ctabtn[3].trim())
  }
  var ctaxy =  variables.cta_txt_size_hex_hexHover_weight_xy.split("|")
  if(ctaxy[4]){
    setXY(cta_txt, ctaxy[4])
  }
  cta_txt.style.backgroundColor = variables.cta_bgHex_bgHexHover.split('|')[0].trim();
  document.head.appendChild(document.createElement('style')).innerHTML = `#cta_txt:hover{color:${variables.cta_txt_size_hex_hexHover_weight_xy.split('|')[2]} !important;}`;
  document.head.appendChild(document.createElement('style')).innerHTML = `#cta_txt:hover{background-color:${variables.cta_bgHex_bgHexHover.split('|')[1]} !important;}`;
}

function setXY(element, xyPos){
  var x = xyPos.trim().split(",")[0];
  var y = xyPos.trim().split(",")[1];
  if(x && Number(x.trim())){
    element.style.setProperty("left", x + "px")
  }
  if(y && Number(y.trim())){
    element.style.setProperty("top", y + "px") 
  }
}

function logoWidthHeight(){
  const values = variables.logoimg_height_width_xy.split("|"); // Split width, height and xy
    const height = values[0]; 
    const width = values[1]; 
    const position = values[2].split(","); // Split x, y coordinates
    const x = position[0];
    const y = position[1];

    // Apply styles to the logo image
    const logoImg = document.getElementById("logo_img"); // Ensure your image has this ID

    if (logoImg) {
        logoImg.style.width = `${width}px`;
        logoImg.style.height = `${height}px`;
        logoImg.style.position = "absolute";  // To apply x, y positioning
        logoImg.style.left = `${x}px`;
        logoImg.style.top = `${y}px`;
    }
}

