      const head = document.getElementById(`f${i}_headline_txt`);
    
   if (head) {
  let htmlContent = head.innerHTML;

  // Step 1: Prevent line breaks between number and time units using non-breaking space
htmlContent = htmlContent.replace(
  /(\d+)\s*[-ŌĆōŌĆö]?\s*(months?|mos\.?|mo|years?|yrs?|yr|Gig|Giga)\b/gi,
  (match, num, unit) => {
    // Check if the original match contained any dash: -, ŌĆō or ŌĆö
    const hyphen = /[-ŌĆōŌĆö]/.test(match) ? '\u2011' : '&nbsp;';
    return `${num}${hyphen}${unit}`;
  }
);

