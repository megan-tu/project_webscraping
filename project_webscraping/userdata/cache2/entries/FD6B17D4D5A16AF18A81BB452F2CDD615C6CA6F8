function findStorelocator(){
  myFT.require(['storelocator'], function (StoreLocator) { 
    var sl = new StoreLocator({
        locatorPath: variables.feed_endpoint,
        numberToReturn: 3, //optional 
        baseURL: "", //optional
        maxDistanceMiles: null, //optional
        maxDistanceKm: null, //optional
        extension: ".js", //optional
        locationOrder: ['impression'] //optional
    }); 
    
    sl.on('storesfound', showStores); 
    sl.on("error",()=>createAdBanner())
        // FOR TESTING LOCALLY
        sl.getNearbyStores({
            "lat": 41.864848,
            "lng": -87.663993,
        });

    sl.init();
  });
}

function showStores(stores) {
  console.log(stores);
  feedItem = stores[0].cty_nm;  
  createAdBanner();
}

function loadFeed(url) {
  // const zip = myFT.get('ftPostal');
  // const zip = '07662';
  // if(!zip) {
  //   feedFail();
  //   return;
  // }

  if(!url) {
    feedLoaded();
    return;
  }


  url = url.replace('[%ZIP%]', zip);
  var feedParams = new FTFeedParams();
  feedParams.segmentId = "";
  feedParams.feedEndpoint = url;
  feedParams.defaultFeedEndpoint = url;
  var ftFeed = new FTFeed(myFT, feedParams);
  ftFeed.getFeed(feedLoaded, feedFail);
}

function feedLoaded(feedArray=[], feedUrl){

  // if(!feedArray){
   
  //   createAdBanner();
  //   return
  // }
  feedItem = feedArray;
 
  display_county = feedArray[0]?.display_county; 

  if(feedArray[0]?.display_county.toLowerCase() == 'n/a' && feedArray[0]?.display_city) display_county = feedArray[0]?.display_city;  

  Tracker.impressionTrackEvent(zip+'|'+display_county);

  createAdBanner();

 
}

function createAdBanner(){
